 *
 * Tests S3DiscordPluginBase: sendDiscordMessage() with various
 * message formats, null channel guard, embed wrapping.
 *
 * ─── USAGE ───────────────────────────────────────────────────────
 *
 *   node SlackersSquadServices/testing/test-s3-discord-plugin-base.js
 *
 * ─── NOTES ───────────────────────────────────────────────────────
 *
 * - Uses an inlined S3DiscordPluginBase stub.
 * - Does NOT require a running SquadJS server or Discord bot.
 *
 */

import assert from 'node:assert/strict';

// ── S3DiscordPluginBase stub ────────────────────────────────────
// Mirrors the real class from plugins/s3-discord-plugin-base.js

class S3DiscordPluginBaseStub {
  constructor(server, options, connectors) {
    this.server = server;
    this.options = options;
    this.connectors = connectors;
    this._s3 = null;
    this._s3db = null;
    this.channel = null;
    this._verboseCalls = [];
  }

  verbose(level, msg) {
    this._verboseCalls.push({ level, msg });
  }

  async sendDiscordMessage(message) {
    if (!this.channel) {
      this.verbose(1, 'Could not send Discord Message. Channel not initialized.');
      return;
    }

    if (typeof message === 'object' && 'embed' in message) {
      message.embed.footer = message.embed.footer || {
        text: 'Slackers Squad Services'
      };
      if (typeof message.embed.color === 'string') {
        message.embed.color = parseInt(message.embed.color, 16);
      }
      message = { ...message, embeds: [message.embed] };
    }

    await this.channel.send(message);
  }
}

// ── Test harness ─────────────────────────────────────────────────

async function runTest(name, fn) {
  try {
    await fn();
    console.log(`✅ ${name}`);
  } catch (err) {
    console.error(`❌ ${name}`);
    console.error(err);
    process.exitCode = 1;
  }
}

// ── Tests ────────────────────────────────────────────────────────

async function main() {

  // ──────────────────────────────────────
  // 1. Plain string message
  // ──────────────────────────────────────
  await runTest('sendDiscordMessage() sends plain string', async () => {
    const plugin = new S3DiscordPluginBaseStub(null, {}, {});
    let sentMessage = null;
    plugin.channel = {
      send: async (msg) => { sentMessage = msg; }
    };

    await plugin.sendDiscordMessage('Hello world');
    assert.equal(sentMessage, 'Hello world');
  });

  // ──────────────────────────────────────
  // 2. Embed object wrapped in embeds array
  // ──────────────────────────────────────
  await runTest('sendDiscordMessage() wraps embed in embeds array', async () => {
    const plugin = new S3DiscordPluginBaseStub(null, {}, {});
    let sentMessage = null;
    plugin.channel = {
      send: async (msg) => { sentMessage = msg; }
    };

    await plugin.sendDiscordMessage({
      embed: {
        title: 'Test Title',
        description: 'Test description'
      }
    });

    assert.ok(sentMessage, 'message should be sent');
    assert.ok(Array.isArray(sentMessage.embeds), 'embeds should be an array');
    assert.equal(sentMessage.embeds.length, 1);
    assert.equal(sentMessage.embeds[0].title, 'Test Title');
    assert.deepEqual(sentMessage.embeds[0].footer, { text: 'Slackers Squad Services' });
  });

  // ──────────────────────────────────────
  // 3. Existing footer preserved
  // ──────────────────────────────────────
  await runTest('sendDiscordMessage() preserves existing footer', async () => {
    const plugin = new S3DiscordPluginBaseStub(null, {}, {});
    let sentMessage = null;
    plugin.channel = {
      send: async (msg) => { sentMessage = msg; }
    };

    await plugin.sendDiscordMessage({
      embed: {
        title: 'Test',
        footer: { text: 'Custom Footer', iconURL: 'https://example.com/icon.png' }
      }
    });

    assert.equal(sentMessage.embeds[0].footer.text, 'Custom Footer');
    assert.equal(sentMessage.embeds[0].footer.iconURL, 'https://example.com/icon.png');
  });

  // ──────────────────────────────────────
  // 4. Hex color parsed to integer
  // ──────────────────────────────────────
  await runTest('sendDiscordMessage() parses hex color strings', async () => {
    const plugin = new S3DiscordPluginBaseStub(null, {}, {});
    let sentMessage = null;
    plugin.channel = {
      send: async (msg) => { sentMessage = msg; }
    };

    await plugin.sendDiscordMessage({
      embed: {
        title: 'Colored',
        color: '00FF00'
      }
    });

    assert.equal(sentMessage.embeds[0].color, 0x00FF00);
  });

  // ──────────────────────────────────────
  // 5. Numeric color left unchanged
  // ──────────────────────────────────────
  await runTest('sendDiscordMessage() leaves numeric colors unchanged', async () => {
    const plugin = new S3DiscordPluginBaseStub(null, {}, {});
    let sentMessage = null;
    plugin.channel = {
      send: async (msg) => { sentMessage = msg; }
    };

    await plugin.sendDiscordMessage({
      embed: {
        title: 'Numeric',
        color: 16711680
      }
    });

    assert.equal(typeof sentMessage.embeds[0].color, 'number');
    assert.equal(sentMessage.embeds[0].color, 16711680);
  });

  // ──────────────────────────────────────
  // 6. Null channel returns early
  // ──────────────────────────────────────
  await runTest('sendDiscordMessage() returns early when channel is null', async () => {
    const plugin = new S3DiscordPluginBaseStub(null, {}, {});
    plugin.channel = null;
    plugin._verboseCalls = [];

    await plugin.sendDiscordMessage('test');

    assert.ok(plugin._verboseCalls.length > 0);
    assert.ok(plugin._verboseCalls[0].msg.includes('Could not send'));
  });

  // ──────────────────────────────────────
  // 7. Already-array embeds passed through
  // ──────────────────────────────────────
  await runTest('sendDiscordMessage() passes through already-array embeds', async () => {
    const plugin = new S3DiscordPluginBaseStub(null, {}, {});
    let sentMessage = null;
    plugin.channel = {
      send: async (msg) => { sentMessage = msg; }
    };

    await plugin.sendDiscordMessage({
      embeds: [
        { title: 'Embed 1' },
        { title: 'Embed 2' }
      ]
    });

    assert.ok(sentMessage.embeds, 'embeds should be present');
    assert.equal(sentMessage.embeds.length, 2);
    assert.equal(sentMessage.embed, undefined);
  });

  // ──────────────────────────────────────
  // 8. Extra properties preserved with embed
  // ──────────────────────────────────────
  await runTest('sendDiscordMessage() preserves extra properties with embed', async () => {
    const plugin = new S3DiscordPluginBaseStub(null, {}, {});
    let sentMessage = null;
    plugin.channel = {
      send: async (msg) => { sentMessage = msg; }
    };

    await plugin.sendDiscordMessage({
      content: 'Preview text',
      embed: { title: 'Embed Title', description: 'Desc' }
    });

    assert.equal(sentMessage.content, 'Preview text');
    assert.equal(sentMessage.embeds.length, 1);
    assert.equal(sentMessage.embeds[0].title, 'Embed Title');
  });

}

await main();

if (!process.exitCode) {
  console.log('\nAll s3-discord-plugin-base tests passed.');
}