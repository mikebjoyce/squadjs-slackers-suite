/**
 * S3 EXPORT/IMPORT TEST
 * Tests s3-export-import.js: three-tier classification, round-trip,
 * file export/restore, per-table try-catch, format auto-detection.
 *
 * Uses real classification table names from s3-export-import.js
 * but avoids S3_SchemaVersions (created by DBService internally).
 *
 * Usage: node SlackersSquadServices/testing/test-s3-export-import.js
 */

import assert from 'node:assert/strict';
import fs from 'node:fs';
import path from 'node:path';
import os from 'node:os';
import DBService from '../utils/db-service.js';
import { Sequelize, DataTypes } from 'sequelize';

let exportToJSON, importFromJSON, validateImportStructure;
let exportToFile, restoreFromFile;

async function init() {
  const mod = await import('../utils/s3-export-import.js');
  exportToJSON = mod.exportToJSON;
  importFromJSON = mod.importFromJSON;
  validateImportStructure = mod.validateImportStructure;
  exportToFile = mod.exportToFile;
  restoreFromFile = mod.restoreFromFile;
}

async function runTest(name, fn) {
  try { await fn(); console.log(`\u2705 ${name}`); }
  catch (err) { console.error(`\u274c ${name}`); console.error(err); process.exitCode = 1; }
}

async function createDb() {
  const seq = new Sequelize({ dialect: 'sqlite', storage: ':memory:', logging: false, define: { freezeTableName: true } });
  await seq.authenticate();
  const db = new DBService({ sequelize: seq, defaultRetry: { attempts: 2, baseDelayMs: 0, jitterMs: 0 } });
  await db.mount();
  return db;
}

// Use real classification table names NOT created by DBService
function defHistorical(db) {
  return db.defineModel('Elo_PlayerStats', {
    eosID: { type: DataTypes.STRING, primaryKey: true },
    rating: { type: DataTypes.INTEGER }
  }, { tableName: 'Elo_PlayerStats', timestamps: false });
}

function defLogging(db) {
  return db.defineModel('S3_PlayerEvents', {
    id: { type: DataTypes.INTEGER, primaryKey: true, autoIncrement: true },
    event: { type: DataTypes.STRING }
  }, { tableName: 'S3_PlayerEvents', timestamps: false });
}

function defEphemeral(db) {
  return db.defineModel('S3_PlayerSessions', {
    eosID: { type: DataTypes.STRING, primaryKey: true },
    data: { type: DataTypes.STRING }
  }, { tableName: 'S3_PlayerSessions', timestamps: false });
}

async function populate(db) {
  const H = defHistorical(db); await H.sync(); await H.create({ eosID: 'p1', rating: 1500 }); await H.create({ eosID: 'p2', rating: 1600 });
  const L = defLogging(db); await L.sync(); await L.create({ event: 'join' });
  const E = defEphemeral(db); await E.sync(); await E.create({ eosID: 's1', data: 'active' });
  return { H, L, E };
}

function tmpDir() { return fs.mkdtempSync(path.join(os.tmpdir(), 's3t-')); }

async function main() {
  await init();

  await runTest('default export includes historical only', async () => {
    const db = await createDb(); await populate(db);
    const r = await exportToJSON(db);
    const names = r.tables.map(t => t.name);
    assert.ok(names.includes('Elo_PlayerStats'));
    assert.ok(!names.includes('S3_PlayerEvents'));
    assert.ok(!names.includes('S3_PlayerSessions'));
  });

  await runTest('tier=logs includes logging tables', async () => {
    const db = await createDb(); await populate(db);
    const r = await exportToJSON(db, { tier: 'logs' });
    const names = r.tables.map(t => t.name);
    assert.ok(names.includes('S3_PlayerEvents'));
    assert.ok(!names.includes('S3_PlayerSessions'));
  });

  await runTest('tier=all includes all tables', async () => {
    const db = await createDb(); await populate(db);
    const r = await exportToJSON(db, { tier: 'all' });
    const names = r.tables.map(t => t.name);
    assert.ok(names.includes('Elo_PlayerStats'));
    assert.ok(names.includes('S3_PlayerEvents'));
    assert.ok(names.includes('S3_PlayerSessions'));
  });

  await runTest('validateImportStructure accepts valid JSON', async () => {
    const db = await createDb(); await populate(db);
    const exp = await exportToJSON(db);
    assert.ok(validateImportStructure(exp, Object.keys(db.models)).valid);
  });

  await runTest('validateImportStructure rejects no format version', () => {
    assert.equal(validateImportStructure({ tables: [] }, []).valid, false);
  });

  await runTest('full round-trip preserves data', async () => {
    const d1 = await createDb(); const { H } = await populate(d1);
    await H.create({ eosID: 'p3', rating: 1700 });
    const exp = await exportToJSON(d1, { tier: 'all' });

    const d2 = await createDb();
    const H2 = defHistorical(d2); await H2.sync();
    const L2 = defLogging(d2); await L2.sync();
    const E2 = defEphemeral(d2); await E2.sync();

    const imp = await importFromJSON(d2, exp);
    assert.ok(imp.imported > 0);
    assert.equal(imp.errors.length, 0);
    assert.equal((await H2.findAll({ raw: true })).length, 3);
  });

  await runTest('dryRun does not write', async () => {
    const d1 = await createDb(); await populate(d1);
    const exp = await exportToJSON(d1);
    const d2 = await createDb(); const H2 = defHistorical(d2); await H2.sync();
    await importFromJSON(d2, exp, { dryRun: true });
    assert.equal((await H2.findAll({ raw: true })).length, 0);
  });

  await runTest('per-table try-catch isolates failures', async () => {
    const d1 = await createDb(); await populate(d1);
    const exp = await exportToJSON(d1, { tier: 'all' });
    const d2 = await createDb(); const H2 = defHistorical(d2); await H2.sync();
    await importFromJSON(d2, exp);
    assert.ok((await H2.findAll({ raw: true })).length > 0);
  });

  await runTest('exportToFile writes JSON file', async () => {
    const db = await createDb(); await populate(db);
    const tmp = tmpDir();
    const r = await exportToFile(db, tmp);
    assert.ok(r);
    assert.ok(r.filename.endsWith('.s3backup.json'));
    assert.ok(fs.existsSync(path.join(tmp, r.filename)));
    fs.rmSync(tmp, { recursive: true, force: true });
  });

  await runTest('restoreFromFile auto-detects JSON', async () => {
    const db = await createDb(); await populate(db);
    const tmp = tmpDir();
    const r = await exportToFile(db, tmp);
    const d2 = await createDb(); const H2 = defHistorical(d2); await H2.sync();
    const restore = await restoreFromFile(r.filename, d2, tmp);
    assert.ok(restore);
    assert.ok((await H2.findAll({ raw: true })).length > 0);
    fs.rmSync(tmp, { recursive: true, force: true });
  });

  await runTest('import with FK handling works', async () => {
    const d1 = await createDb(); await populate(d1);
    const exp = await exportToJSON(d1);
    const d2 = await createDb(); const H2 = defHistorical(d2); await H2.sync();
    await importFromJSON(d2, exp);
    assert.ok((await H2.findAll({ raw: true })).length > 0);
  });
}

await main();
if (!process.exitCode) console.log('\nAll export-import tests passed.');